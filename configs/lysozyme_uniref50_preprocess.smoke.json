{
  "input": {
    "path": "data/lysozyme_uniref50/lysozyme_uniref50_family_input.sample256.csv",
    "format": "csv",
    "id_col": "seq_id",
    "sequence_col": "sequence",
    "description_col": "description",
    "source_db_col": "source_db",
    "family_tag_col": "family_tag"
  },
  "output_dir": "data/lysozyme_uniref50/smoke_preprocessed",
  "family": {
    "seq_id_prefix": "lysozyme_uniref50",
    "source_db": "UniRef50",
    "family_tag": "lysozyme_uniref50_broad",
    "min_length": 60,
    "max_length": 400,
    "deduplicate_by_sequence": true,
    "drop_non_canonical": true
  },
  "scoring": {
    "enabled": true,
    "device": "mps",
    "batch_size": 8,
    "esm_model": "650M",
    "sol_predictor_path": "saved_predictors/sol_predictor_final.pt",
    "therm_predictor_path": "saved_predictors/therm_predictor_nocdhit.pt"
  },
  "split": {
    "train_fraction": 0.8,
    "seed": 42
  },
  "selection": {
    "positive_fraction": 0.2,
    "negative_fraction": 0.3,
    "test_target_size": 20
  },
  "reference_pool": {
    "enabled": true,
    "source": "test",
    "size": 20,
    "shuffle": true
  }
}
